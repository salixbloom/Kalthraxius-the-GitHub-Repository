# ── Kalthraxius node — example environment ───────────────────────────────────
# Copy this file to .env (or export the vars directly) before running any node.
# Lines marked "required" have no default and the process will refuse to start
# without them.  All other lines show the built-in default.

# ── Identity ─────────────────────────────────────────────────────────────────

# Path where the Ed25519 private key is persisted.
KAL_IDENTITY_FILE=node.key

# ── Networking ───────────────────────────────────────────────────────────────

# libp2p TCP listen multiaddr. (Defualt : /ip4/0.0.0.0/tcp/4001)
KAL_LISTEN=/ip4/0.0.0.0/tcp/4001

# libp2p WebSocket listen multiaddr. (Default : /ip4/0.0.0.0/tcp/4002/ws)
KAL_WSLISTEN=/ip4/0.0.0.0/tcp/4002/ws

# Comma-separated multiaddrs advertised to the network.  Required behind NAT
# or Docker so remote peers can dial back.
# Example: /dns4/jobs.example.com/tcp/4001
KAL_ANNOUNCE=

# Comma-separated bootstrap peer multiaddrs to dial on startup.  Peer IDs are
# resolved automatically during the handshake if the /p2p/<peerId> suffix is
# absent.  Leave empty to start an isolated node.
# Example: /ip4/1.2.3.4/tcp/4001,/ip4/1.2.3.4/tcp/4001/p2p/(peerID)...
KAL_BOOTSTRAP=

# Set to "1" or "true" to keep loopback / private addresses in the DHT routing
# table.  Useful for local dev clusters; leave off in production.
KAL_ALLOW_PRIVATE=

# ── Logging ──────────────────────────────────────────────────────────────────

# Directory where structured log files are written.
# (Default : ./logs)
LOG_DIR=./logs

# Minimum log level emitted: trace | debug | info | warn | error | fatal
# (Default : info)
LOG_LEVEL=info

# ── Aggregator node ──────────────────────────────────────────────────────────
# (used by aggregator.ts and aggregator-scraper.ts)

# SQLite database file for the persistent job store. 
# (Default : aggregator-store.db)
KAL_STORE_DB=aggregator-store.db

# SQLite database file for the full-text search index.
# (Default : aggregator-search.db)
KAL_SEARCH_DB=aggregator-search.db

# Comma-separated platform IDs to subscribe to.  Defaults to all platforms
# listed in data/platforms.json when left empty.
# Example: linkedin,greenhouse,lever
KAL_PLATFORMS=

# How often (ms) the aggregator re-announces itself and refreshes bloom filters.
KAL_ANNOUNCE_MS=30000

# ── Scraper node ─────────────────────────────────────────────────────────────
# (used by scraper.ts and aggregator-scraper.ts)

# [required] Path to a platform descriptor JSON file that defines the scrape
# target, CSS selectors, and rate-limit settings.
# Example: data/descriptors/linkedin.json
KAL_DESCRIPTOR=

# Interval between scrape passes in milliseconds (default 5 minutes).
KAL_SCRAPE_MS=300000

# How long a scrape claim is held in the DHT before other nodes may take over
# the target (default 30 minutes).
KAL_CLAIM_TTL_MS=1800000

# Set to "1" to use the hardened stealth fetcher (headless browser mode).
# Slower but avoids bot-detection on JavaScript-heavy sites.
KAL_STEALTH=

# Set to "1" to run a single scrape pass and exit.  Useful for cron jobs or
# one-off testing runs.
KAL_ONCE=
